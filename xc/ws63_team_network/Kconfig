config SLE_TEAM_ST7789_X_OFFSET
    int "ST7789 column offset"
    default 40
    depends on SLE_TEAM_ST7789_ENABLE
    help
        Confirmed v4.4+ landscape 1.14 inch ST7789 module starts at column 40.
        Keep this paired with WIDTH=240, HEIGHT=135, Y_OFFSET=53, MADCTL=0x60.

